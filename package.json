{
  "name": "@server/next",
  "version": "0.37.1",
  "description": "A fully-fledged web server with routing, file uploads, sessions, static files, schema validation, websockets, testing, etc.",
  "homepage": "https://server-js.com/",
  "repository": "github:franciscop/server-next",
  "author": "Francisco Presencia <public@francisco.io> (https://francisco.io/)",
  "funding": "https://www.paypal.me/franciscopresencia/19",
  "license": "UNLICENSED",
  "keywords": [
    "server",
    "node",
    "server.js"
  ],
  "scripts": {
    "build": "bunx tsup src/index.ts --format esm --dts --out-dir . --target node24",
    "start": "bun test --watch",
    "lint": "npx tsc --noEmit && npx @biomejs/biome lint ./src --skip=lint/suspicious/noExplicitAny --skip=lint/style/noParameterAssign --skip=lint/suspicious/noConfusingVoidType --skip=lint/complexity/noBannedTypes",
    "test": "npm run test:bun && tsc --noEmit",
    "test:bun": "bun test",
    "test:jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "main": "index.js",
  "type": "module",
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "src/jsx/"
  ],
  "exports": {
    ".": "./index.js",
    "./index.d.ts": "./index.d.ts",
    "./jsx-runtime": {
      "types": "./src/jsx/jsx-runtime.d.ts",
      "default": "./src/jsx/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./src/jsx/jsx-runtime.d.ts",
      "default": "./src/jsx/jsx-dev-runtime.js"
    }
  },
  "documentation.page": {
    "title": "Server JS - A modern web server for Bun and Node.js",
    "home": "./docs/index.html",
    "menu": {
      "Documentation": "/documentation",
      "Github": "https://github.com/franciscop/server-next"
    },
    "documentation": {
      "Documentation": ["docs/0. Documentation.md", "docs/1. Getting Started.md"],
      "Guides": "docs/2. Guides.md",
      "Options": "docs/3. Options.md",
      "Router": "docs/4. Router.md",
      "Context": "docs/5. Context.md",
      "Reply": "docs/6. Reply.md",
      "Authentication": "docs/7. Authentication.md",
      "Testing": "docs/8. Testing.md",
      "Platforms": "docs/9. Platforms.md",
      "FAQ": "docs/A. FAQ.md"
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.0",
    "bucket": "^0.4.0",
    "bun": "^1.3.13",
    "check-dts": "^0.8.2",
    "jest": "^29.7.0",
    "polystore": "^0.21.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "jest": {
    "testEnvironment": "jest-environment-node",
    "transform": {}
  }
}
